// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  brandName String
  password  String
  role      Role     @default(CLIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects  Project[]
  quotes    Quote[]
}

enum Role {
  ADMIN
  CLIENT
}

model Quote {
  id          Int      @id @default(autoincrement())
  userId      Int?
  product     String   // tshirt | hoodie | veste | jogging
  materialType String
  grammage     String
  branding     String
  brandingLocations Int
  neckLabel    String
  hangtag      String
  packaging    String
  hasPatron    String
  wantsPrototype String
  leadTime     String?
  quantity    Int
  unitPrice   Float?
  totalPrice  Float?
  setupFees   Float?
  brandName   String
  contactName String
  email       String
  phone       String
  schemaFile  String?
  patronFile  String?
  notes       String?  @db.Text
  status      QuoteStatus @default(PENDING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User?    @relation(fields: [userId], references: [id])
  project     Project?
}

enum QuoteStatus {
  PENDING
  CONTACTED
  PRICED
  PAID
  VALIDATED
  REJECTED
}

model Project {
  id          Int      @id @default(autoincrement())
  userId      Int
  quoteId     Int?     @unique
  reference   String   @unique
  product     String
  quantity    Int
  status      ProjectStatus @default(QUOTE_VALIDATED)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  quote       Quote?   @relation(fields: [quoteId], references: [id])
  materials   Material[]
  shipments   Shipment[]
}

enum ProjectStatus {
  QUOTE_VALIDATED
  AWAITING_MATERIAL
  MATERIAL_RECEIVED
  CUTTING
  SEWING
  QUALITY_CHECK
  READY_TO_SHIP
  SHIPPED
  DELIVERED
}

model Material {
  id              Int      @id @default(autoincrement())
  projectId       Int
  carrier         String
  trackingNumber  String?
  estimatedArrival DateTime?
  receivedAt      DateTime?
  quantityMeters  Float?
  notes           String?  @db.Text
  createdAt       DateTime @default(now())

  project         Project  @relation(fields: [projectId], references: [id])
}

model Shipment {
  id          Int      @id @default(autoincrement())
  projectId   Int
  type        ShipmentType @default(TO_CLIENT_WAREHOUSE)
  carrier     String?
  trackingNumber String?
  address     String?  @db.Text
  shippedAt   DateTime?
  deliveredAt DateTime?
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id])
}

enum ShipmentType {
  TO_CLIENT_WAREHOUSE
  TO_END_CUSTOMER
}
