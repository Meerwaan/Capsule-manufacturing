# Capsule Manufacturing — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs

# === Base de données MySQL (MAMP) ===
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:root@localhost:8889/capsule_manufacturing"

# === NextAuth ===
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-this-to-a-random-secret-in-production"
